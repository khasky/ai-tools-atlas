---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { catalog } from "../lib/catalog";
import { withBase } from "../lib/paths";

const jobs = catalog.categories.filter((c) => c.axis_type === "JOB");
---

<Layout
  title="Use cases"
  description="Writing, coding, transcription, automation, and the rest of the task axis."
>
  <SiteHeader slot="header" />
  <h1 class="font-display text-3xl font-bold text-ink-950">Use cases</h1>
  <p class="mt-3 max-w-2xl text-ink-600">This axis is separate from modality and buyer domain in the taxonomy.</p>
  <ul class="mt-10 grid gap-3 sm:grid-cols-2">
    {
      jobs.map((c) => (
        <li>
          <a href={withBase(`/use-case/${c.slug}`)} class="block rounded-xl border border-ink-200 bg-white p-4 shadow-sm hover:border-accent/40">
            <span class="font-medium text-ink-900">{c.name}</span>
            <p class="mt-1 text-sm text-ink-500">{c.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
</Layout>
