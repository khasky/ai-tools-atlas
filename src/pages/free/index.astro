---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import ToolCard from "../../components/ToolCard.astro";
import Pagination from "../../components/Pagination.astro";
import { allTools } from "../../lib/catalog";
import { sortFreeTools } from "../../lib/sorts";
import { paginate } from "../../lib/paginate";

const list = sortFreeTools(allTools);
const { items, totalPages, total } = paginate(list, 1);
---

<Layout
  title="Free and freemium AI tools"
  description="Free or freemium tools in this build. Metrics sort first when we have them, then A–Z."
>
  <SiteHeader slot="header" />
  <div class="mb-8">
    <h1 class="font-display text-3xl font-bold text-ink-950">Free tools</h1>
    <p class="mt-2 text-ink-600">Free and freemium as of this snapshot. Check the vendor before you rely on price.</p>
    <p class="mt-1 text-sm text-ink-500">
      {total.toLocaleString()} tools · metrics first when we have them, then A–Z
    </p>
  </div>
  <div class="flex flex-col gap-4">
    {items.map((t) => <ToolCard tool={t} />)}
  </div>
  <Pagination basePath="/free" page={1} totalPages={totalPages} />
</Layout>
