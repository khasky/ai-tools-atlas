---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import ToolCard from "../../components/ToolCard.astro";
import type { Tool } from "../../types/catalog";
import { getCategory, getTool, allTools } from "../../lib/catalog";
import { withBase } from "../../lib/paths";
import { absoluteUrl, configuredSiteUrl, REPO_URL, AUTHOR_LOGIN, AUTHOR_URL } from "../../lib/site-meta";
import { inlineMarkdownLinksToHtml, plainTextFromMarkdown } from "../../lib/inline-markdown";

export function getStaticPaths() {
  return allTools.map((t) => ({ params: { slug: t.slug } }));
}

const slug = Astro.params.slug!;
const tool = getTool(slug);
if (!tool) throw new Error(`Unknown tool: ${slug}`);

const primaryCat = getCategory(tool.primary_category_slug);
const alternatives = tool.alternative_slugs.map((s) => getTool(s)).filter((x): x is Tool => Boolean(x));

const siteRoot = configuredSiteUrl();
const profileUrl = absoluteUrl(`/tools/${tool.slug}`);

const shortPlain = plainTextFromMarkdown(tool.short_description);
const shortIntroHtml = inlineMarkdownLinksToHtml(tool.short_description);
const longAboutHtml = inlineMarkdownLinksToHtml(tool.long_description);

/** Collapse markdown/plain to one line for “is this the same blurb as the hero?” checks. */
function normalizeComparableBlurb(s: string): string {
  return plainTextFromMarkdown(s).replace(/\s+/g, " ").trim().toLowerCase();
}

const longPlainNorm = normalizeComparableBlurb(tool.long_description);
const shortPlainNorm = normalizeComparableBlurb(tool.short_description);
const showAboutSection = longPlainNorm.length > 0 && longPlainNorm !== shortPlainNorm;

const jsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: tool.canonical_name,
  description: shortPlain.slice(0, 500),
  applicationCategory: "DeveloperApplication",
  operatingSystem: tool.platforms.length ? tool.platforms.join(", ") : "Web",
  url: tool.website_url,
  sameAs: tool.external_links.filter((l) => l.type === "website" || l.type === "docs").map((l) => l.url),
  publisher: {
    "@type": "Organization",
    name: AUTHOR_LOGIN,
    url: AUTHOR_URL,
    sameAs: [REPO_URL],
  },
};
if (profileUrl) {
  jsonLd.mainEntityOfPage = {
    "@type": "WebPage",
    "@id": profileUrl,
    url: profileUrl,
    isPartOf: siteRoot ? { "@type": "WebSite", name: "AI Tools Atlas", url: siteRoot } : undefined,
  };
}
if (tool.pricing_model === "FREE") {
  jsonLd.offers = {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free",
  };
}

const breadcrumbLd =
  siteRoot &&
  profileUrl &&
  JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteRoot },
      { "@type": "ListItem", position: 2, name: "Tools", item: absoluteUrl("/tools") },
      { "@type": "ListItem", position: 3, name: tool.canonical_name, item: profileUrl },
    ],
  });
---

<Layout
  title={`${tool.canonical_name} (tool)`}
  description={shortPlain}
  canonicalPath={`/tools/${tool.slug}`}
  ogType="article"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  {breadcrumbLd && <script type="application/ld+json" slot="head" set:html={breadcrumbLd} />}
  <SiteHeader slot="header" />

  <article>
    <header class="border-b border-ink-200 pb-8">
      <div class="flex flex-wrap items-start gap-6">
        <div class="min-w-0 flex-1">
          <p class="text-sm font-medium uppercase tracking-wide text-accent">Tool profile</p>
          <h1 class="mt-2 font-display text-3xl font-bold text-ink-950 sm:text-4xl">{tool.canonical_name}</h1>
          {
            tool.aliases.length > 0 && (
              <p class="mt-2 text-sm text-ink-600">
                Also known as: <span class="text-ink-800">{tool.aliases.join(", ")}</span>
              </p>
            )
          }
          <p class="mt-4 max-w-3xl text-lg text-ink-700" set:html={shortIntroHtml} />
          {
            tool.sponsored && (
              <p class="mt-3 inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-900">Sponsored listing</p>
            )
          }
        </div>
      </div>
      <dl class="mt-6 text-sm">
        <div>
          <dt class="text-ink-500">Primary category</dt>
          <dd class="mt-1 font-medium text-ink-900">
            <a class="text-accent hover:underline" href={withBase(`/category/${tool.primary_category_slug}`)}>
              {primaryCat?.name ?? tool.primary_category_slug}
            </a>
          </dd>
        </div>
      </dl>
    </header>

    <div class="grid gap-10 py-10 lg:grid-cols-3">
      <div class="lg:col-span-2 space-y-10">
        {
          showAboutSection && (
            <section aria-labelledby="desc-heading">
              <h2 id="desc-heading" class="font-display text-xl font-semibold text-ink-950">About</h2>
              <div class="mt-3 whitespace-pre-line text-ink-700" set:html={longAboutHtml} />
            </section>
          )
        }

        <section aria-labelledby="tax-heading">
          <h2 id="tax-heading" class="font-display text-xl font-semibold text-ink-950">Taxonomy</h2>
          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            <div>
              <h3 class="text-sm font-semibold text-ink-800">Use cases</h3>
              <ul class="mt-2 flex flex-wrap gap-2">
                {
                  tool.use_case_slugs.map((s) => (
                    <li>
                      <a class="rounded-full bg-ink-100 px-2 py-1 text-xs text-ink-800 hover:bg-ink-200" href={withBase(`/use-case/${s}`)}>
                        {s}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-ink-800">Modalities</h3>
              <ul class="mt-2 flex flex-wrap gap-2">
                {
                  tool.modality_slugs.map((s) => (
                    <li>
                      <a class="rounded-full bg-ink-100 px-2 py-1 text-xs text-ink-800 hover:bg-ink-200" href={withBase(`/modality/${s}`)}>
                        {s}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-ink-800">Domains</h3>
              <ul class="mt-2 flex flex-wrap gap-2">
                {
                  tool.domain_slugs.map((s) => (
                    <li>
                      <a class="rounded-full bg-ink-100 px-2 py-1 text-xs text-ink-800 hover:bg-ink-200" href={withBase(`/domain/${s}`)}>
                        {s}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-ink-800">Capabilities</h3>
              <p class="mt-2 text-sm text-ink-700">{tool.capability_tags.join(", ")}</p>
            </div>
          </div>
        </section>

        {
          tool.screenshots.length > 0 && (
            <section aria-labelledby="shots-heading">
              <h2 id="shots-heading" class="font-display text-xl font-semibold text-ink-950">Screenshots</h2>
              <div class="mt-4 grid gap-4 sm:grid-cols-2">
                {tool.screenshots.map((s) => (
                  <figure class="overflow-hidden rounded-xl border border-ink-200 bg-ink-100">
                    <img src={s.url} alt={s.alt} class="h-auto w-full object-cover" loading="lazy" width="800" height="450" />
                  </figure>
                ))}
              </div>
            </section>
          )
        }

        <section aria-labelledby="alt-heading">
          <h2 id="alt-heading" class="font-display text-xl font-semibold text-ink-950">Alternatives</h2>
          <div class="mt-4 flex flex-col gap-4">
            {alternatives.map((t) => <ToolCard tool={t} />)}
          </div>
        </section>
      </div>

      <aside class="space-y-8 lg:col-span-1">
        <section class="rounded-xl border border-ink-200 bg-white p-5 shadow-sm" aria-labelledby="links-heading">
          <h2 id="links-heading" class="font-display text-lg font-semibold text-ink-950">External links</h2>
          <ul class="mt-3 space-y-2 text-sm">
            {
              tool.external_links.map((l) => (
                <li>
                  <a class="text-accent hover:underline" href={l.url} target="_blank" rel="noopener noreferrer">
                    {l.label}
                  </a>
                  <span class="text-ink-400"> · {l.type}</span>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="rounded-xl border border-ink-200 bg-white p-5 shadow-sm" aria-labelledby="facts-heading">
          <h2 id="facts-heading" class="font-display text-lg font-semibold text-ink-950">Quick facts</h2>
          <dl class="mt-3 space-y-2 text-sm">
            <div>
              <dt class="text-ink-500">Platforms</dt>
              <dd class="text-ink-800">{tool.platforms.join(", ")}</dd>
            </div>
            <div>
              <dt class="text-ink-500">Open source</dt>
              <dd class="text-ink-800">{tool.open_source ? "Yes" : "No"}</dd>
            </div>
            <div>
              <dt class="text-ink-500">Free plan</dt>
              <dd class="text-ink-800">{tool.free_plan_available ? "Yes" : "No"}</dd>
            </div>
            <div>
              <dt class="text-ink-500">API / docs</dt>
              <dd class="text-ink-800">{tool.api_docs_available ? "Docs/API surfaced" : "Limited / unknown"}</dd>
            </div>
            <div>
              <dt class="text-ink-500">Security / compliance (claims)</dt>
              <dd class="text-ink-800">{tool.security_compliance.join(", ")}</dd>
            </div>
          </dl>
        </section>
      </aside>
    </div>
  </article>
</Layout>
