---
import Layout from "../../../layouts/Layout.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import ToolCard from "../../../components/ToolCard.astro";
import Pagination from "../../../components/Pagination.astro";
import { allTools } from "../../../lib/catalog";
import { sortCatalogTools } from "../../../lib/sorts";
import { paginate, pageCount } from "../../../lib/paginate";

export function getStaticPaths() {
  const sorted = sortCatalogTools(allTools);
  const tp = pageCount(sorted.length);
  if (tp <= 1) return [];
  return Array.from({ length: tp - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const pageNum = Number(Astro.params.page);
const sorted = sortCatalogTools(allTools);
const { items, totalPages, total } = paginate(sorted, pageNum);
---

<Layout
  title={`All tools, page ${pageNum}`}
  description={`Page ${pageNum} of the full tool list (${total.toLocaleString()} total).`}
>
  <SiteHeader slot="header" />
  <div class="mb-8">
    <h1 class="font-display text-3xl font-bold text-ink-950">All tools</h1>
    <p class="mt-2 text-sm text-ink-500">Page {pageNum} of {totalPages} · {total.toLocaleString()} tools</p>
  </div>
  <div class="flex flex-col gap-4">
    {items.map((t) => <ToolCard tool={t} />)}
  </div>
  <Pagination basePath="/tools" page={pageNum} totalPages={totalPages} />
</Layout>
