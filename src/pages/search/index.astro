---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { withBase } from "../../lib/paths";
---

<Layout
  title="Search AI tools"
  description="Search names, blurbs, categories, tags, integrations, deployment, and platforms."
>
  <SiteHeader slot="header" />
  <h1 class="font-display text-3xl font-bold text-ink-950">Search</h1>
  <p class="mt-2 text-ink-600">
    A few synonyms are folded in so informal queries (e.g. "coding ai" or "meeting notes") still hit.
  </p>
  <form class="mt-8 flex max-w-xl flex-col gap-3 sm:flex-row" method="get" action={withBase("/search")} role="search">
    <label class="sr-only" for="search-q">Query</label>
    <input
      id="search-q"
      name="q"
      type="search"
      class="w-full rounded-xl border border-ink-300 bg-white px-4 py-3 text-ink-900 shadow-inner outline-none ring-accent focus:ring-2"
      placeholder="Search tools…"
    />
    <button type="submit" class="rounded-xl bg-accent px-6 py-3 font-semibold text-white hover:bg-accent-dark">Search</button>
  </form>
  <p id="search-status" class="mt-4 text-sm text-ink-600" aria-live="polite"></p>
  <div id="search-results" class="mt-8 flex flex-col gap-4"></div>
  <script>
    import { initSearchPage } from "../../scripts/client-search";
    initSearchPage();
  </script>
</Layout>
