---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import ToolCard from "../../components/ToolCard.astro";
import Pagination from "../../components/Pagination.astro";
import { allTools } from "../../lib/catalog";
import { sortOpenSourceTools } from "../../lib/sorts";
import { paginate } from "../../lib/paginate";

const list = sortOpenSourceTools(allTools);
const { items, totalPages, total } = paginate(list, 1);
---

<Layout
  title="Open-source AI tools"
  description="Open-source projects in this catalog. Metrics first when the build has them, then A–Z."
>
  <SiteHeader slot="header" />
  <div class="mb-8">
    <h1 class="font-display text-3xl font-bold text-ink-950">Open source</h1>
    <p class="mt-2 text-ink-600">Whatever upstream marked as open source. Order follows snapshot metrics when we have them; otherwise name.</p>
    <p class="mt-1 text-sm text-ink-500">
      {total.toLocaleString()} tools · metrics first when we have them, then A–Z
    </p>
  </div>
  <div class="flex flex-col gap-4">
    {items.map((t) => <ToolCard tool={t} />)}
  </div>
  <Pagination basePath="/open-source" page={1} totalPages={totalPages} />
</Layout>
