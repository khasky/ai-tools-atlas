---
import type { Tool } from "../types/catalog";
import { withBase } from "../lib/paths";
import { inlineMarkdownLinksToHtml } from "../lib/inline-markdown";

interface Props {
  tool: Tool;
}
const { tool } = Astro.props;
const shortDescriptionHtml = inlineMarkdownLinksToHtml(tool.short_description);
---

<article
  class:list={[
    "rounded-xl border bg-white p-5 shadow-sm transition hover:border-accent/40 hover:shadow-md",
    tool.sponsored ? "border-amber-300 ring-1 ring-amber-200/60" : "border-ink-200",
  ]}
>
  <div class="flex flex-wrap items-start gap-3">
    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-center gap-2">
        <a href={withBase(`/tools/${tool.slug}`)} class="font-display text-lg font-semibold text-ink-950 hover:text-accent">
          {tool.canonical_name}
        </a>
        {
          tool.sponsored && (
            <span class="rounded-full bg-amber-100 px-2 py-0.5 text-xs font-semibold text-amber-900">Sponsored</span>
          )
        }
      </div>
      <p class="mt-2 line-clamp-2 text-sm text-ink-600" set:html={shortDescriptionHtml} />
      <div class="mt-3 flex flex-wrap gap-2 text-xs">
        <span class="rounded-full bg-ink-100 px-2 py-0.5 text-ink-700">{tool.primary_category_slug}</span>
        {
          tool.platforms.slice(0, 4).map((p) => (
            <span class="rounded-full border border-ink-200 px-2 py-0.5 text-ink-600">{p}</span>
          ))
        }
      </div>
    </div>
  </div>
</article>
