---
import { withBase } from "../lib/paths";

interface Props {
  basePath: string;
  page: number;
  totalPages: number;
  /** How many page numbers to show on each side of the current page (excluding first/last). */
  siblingDelta?: number;
}

const { basePath, page, totalPages, siblingDelta = 2 } = Astro.props;

function href(p: number): string {
  const sub = p <= 1 ? basePath : `${basePath}/page/${p}`;
  return withBase(sub);
}

/**
 * e.g. total=100, current=6, delta=2 → [1, 'gap', 4, 5, 6, 7, 8, 'gap', 100]
 */
function pageSequence(current: number, total: number, delta: number): (number | "gap")[] {
  if (total < 1) return [];
  if (total === 1) return [1];
  const set = new Set<number>();
  set.add(1);
  set.add(total);
  for (let i = current - delta; i <= current + delta; i++) {
    if (i >= 1 && i <= total) set.add(i);
  }
  const sorted = [...set].sort((a, b) => a - b);
  const out: (number | "gap")[] = [];
  let prev = 0;
  for (const n of sorted) {
    if (prev > 0 && n - prev > 1) out.push("gap");
    out.push(n);
    prev = n;
  }
  return out;
}

const sequence = pageSequence(page, totalPages, siblingDelta);

const btn =
  "rounded-lg border border-ink-300 bg-white px-3 py-2 text-sm font-medium text-ink-800 hover:bg-ink-50 transition-colors";
const numBase =
  "min-w-[2.5rem] rounded-lg border px-3 py-2 text-center text-sm font-medium transition-colors";
const numActive = "border-accent bg-accent text-white";
const numIdle = "border-ink-200 bg-white text-ink-800 hover:bg-ink-50";

const showPrevBlock = page > 1;
const showNextBlock = page < totalPages;
const vSep = "hidden h-8 w-px bg-ink-200 sm:inline-block";
---

{
  totalPages > 0 && (
    <nav class="flex flex-col items-center gap-4 pt-10" aria-label="Pagination">
      <div class="flex flex-wrap items-center justify-center gap-2">
        {
          showPrevBlock && (
            <>
              <a class={btn} href={href(1)} aria-label="First page">
                First
              </a>
              <a class={btn} href={href(page - 1)} rel="prev" aria-label="Previous page">
                Previous
              </a>
              <span class={vSep} aria-hidden="true" />
            </>
          )
        }

        {
          sequence.map((item) =>
            item === "gap" ? (
              <span class="px-1 text-sm font-medium text-ink-400 select-none" aria-hidden="true">
                …
              </span>
            ) : (
              <a
                href={href(item)}
                class:list={[numBase, item === page ? numActive : numIdle]}
                aria-current={item === page ? "page" : undefined}
              >
                {item}
              </a>
            )
          )
        }

        {
          showNextBlock && (
            <>
              <span class={vSep} aria-hidden="true" />
              <a class={btn} href={href(page + 1)} rel="next" aria-label="Next page">
                Next
              </a>
              <a class={btn} href={href(totalPages)} aria-label="Last page">
                Last
              </a>
            </>
          )
        }
      </div>
    </nav>
  )
}
